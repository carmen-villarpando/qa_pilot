# GitHub Configuration
GITHUB_TOKEN=your_github_personal_access_token

# AI Provider Configuration
# Options: github_models (free tier, recommended), openai, local
AI_PROVIDER=github_models

# GitHub Models Configuration (if using github_models provider) - FREE TIER
GITHUB_MODELS_TOKEN=your_github_models_token

# OpenAI Configuration (if using openai provider)
OPENAI_API_KEY=your_openai_api_key

# Local Model Configuration (if using local provider)
# Make sure Ollama is running: ollama serve
LOCAL_MODEL=llama3.2
